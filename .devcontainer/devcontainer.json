{
  "name": "AI Academy (universal image)",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers-contrib/features/uv:1": {}
  },
  "waitFor": "onCreateCommand",
  "postCreateCommand": "uv sync",
  "forwardPorts": [
    8501,
    8888,
    5000
  ],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "8888": {
      "label": "JupyterLab Server",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "5000": {
      "label": "MLflow Dashboard",
      "onAutoForward": "notify",
      "visibility": "private"
    }
  },
  "containerEnv": {
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md"
      ]
    },
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
        "jupyter.kernels.default": "python3"
      }
    },
    "repositories": {
      "pchoinsk/ai-academy": {
        "permissions": {
          "contents": "read",
          "models": "read"
        }
      }
    }
  }
}