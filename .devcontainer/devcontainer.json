{
  "name": "AI Academy (universal image based)",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
      "ghcr.io/devcontainers/features/python:1": {
        "installJupyterlab": "true"
      }
  },
  "waitFor": "onCreateCommand",
  "updateContentCommand": "bash .devcontainer/setup.sh",
  "postCreateCommand": "",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md"
      ]
    },
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "github.copilot",
        "github.copilot-chat"
      ]
    },
    "repositories": {
      "pchoinsk/ai-academy": {
        "permissions": {
          "contents": "read",
          "models": "read"
        }
      }
    }
  }
}