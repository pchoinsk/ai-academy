{
  "name": "AI Academy (Python image based + custom JupyterLab)",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers-contrib/features/uv:1": {}
  },
  "waitFor": "onCreateCommand",
  "updateContentCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md"
      ]
    },
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
        "jupyter.kernels.default": "ai-academy"
      }
    },
    "repositories": {
      "pchoinsk/ai-academy": {
        "permissions": {
          "contents": "read",
          "models": "read"
        }
      }
    }
  }
}